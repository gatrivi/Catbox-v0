# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Telemetry Permanent Storage (PostgreSQL Connection String)
# Example: postgresql://postgres:password@localhost:5432/catbox_telemetry
DATABASE_URL="postgresql://postgres:password@localhost:5432/catbox_telemetry"

# Telemetry Cache Storage (Redis Connection String)
# Example: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# Adsterra Publisher Smartlink (terminal/CLI daemon — click fallback inventory)
# Publisher account → Settings → API → GENERATE NEW TOKEN
ADSTERRA_API_KEY="your_api_token"
# Smartlinks → Add Smartlink → copy URL (NOT the Advertiser API)
ADSTERRA_SMARTLINK_URL="https://your-smartlink-url.example"
# Optional: filter Publisher API stats reconciliation
ADSTERRA_PLACEMENT_ID=""
ADSTERRA_DOMAIN_ID=""
# Optional: terminal status-bar copy (max ~75 chars recommended)
ADSTERRA_DISPLAY_TEXT="Sponsored — tap to explore"

