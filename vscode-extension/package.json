{
  "name": "catbox-vscode",
  "displayName": "Catbox Status Bar Streamer",
  "description": "Custom high-frequency ad dispatching telemetry & VS Code extension sponsor panel.",
  "version": "1.3.0",
  "publisher": "Catbox",
  "license": "AGPL-3.0-only",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "catbox.openAd",
        "title": "Catbox: Open Sponsor Asset",
        "category": "Catbox"
      },
      {
        "command": "catbox.toggleStream",
        "title": "Catbox: Toggle Shimmer Display",
        "category": "Catbox"
      },
      {
        "command": "catbox.revert",
        "title": "Catbox: Revert Claude Settings & Clean Up",
        "category": "Catbox"
      }
    ],
    "configuration": {
      "title": "Catbox",
      "properties": {
        "catbox.shimmerEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Status Bar sponsored text rotation and impression earning."
        }
      }
    }
  }
}
