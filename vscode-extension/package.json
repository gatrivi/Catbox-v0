{
  "name": "catbox-vscode",
  "displayName": "Catbox Status Bar Streamer",
  "description": "Text-native status bar ads and optional pets-sized visual sponsor panel.",
  "version": "1.4.0",
  "publisher": "Catbox",
  "license": "AGPL-3.0-only",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Catbox",
      "properties": {
        "catbox.visualAd.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show optional pets-sized visual sponsor panel in the Catbox sidebar (opt-in)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "catbox",
          "title": "Catbox",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "catbox": [
        {
          "type": "webview",
          "id": "catbox.visualAd",
          "name": "Sponsor",
          "when": "config.catbox.visualAd.enabled"
        }
      ]
    },
    "commands": [
      {
        "command": "catbox.openAd",
        "title": "Catbox: Open Sponsor Asset",
        "category": "Catbox"
      },
      {
        "command": "catbox.enableVisualAd",
        "title": "Catbox: Enable Visual Sponsor Panel",
        "category": "Catbox"
      },
      {
        "command": "catbox.hideVisualAd",
        "title": "Catbox: Hide Visual Sponsor Panel",
        "category": "Catbox"
      }
    ]
  }
}
